# ==============================================================
# EQUILIBRE — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores reais
# cp .env.example .env
# ==============================================================

# --- Supabase (obrigatório) ---
# URL do seu projeto Supabase (ex: https://xyzabc.supabase.co)
VITE_SUPABASE_URL=

# Chave anônima pública do Supabase (anon key)
VITE_SUPABASE_KEY=

# Chave de serviço do Supabase — SOMENTE para operações admin
# ⚠️ NUNCA exponha esta chave no frontend em produção
VITE_SUPABASE_SERVICE_KEY=

# --- Web Push / VAPID (obrigatório para notificações push) ---
# Gere as chaves com: npx web-push generate-vapid-keys
# Coloque a chave PÚblica aqui (exposta ao frontend)
VITE_VAPID_PUBLIC_KEY=
# Coloque a chave PRIVADA apenas no backend / Edge Function (NUNCA no frontend)
# VAPID_PRIVATE_KEY=
