# ==============================================================
# EQUILIBRE — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores reais
# cp .env.example .env
# ==============================================================

# --- Supabase (obrigatório) ---
# URL do seu projeto Supabase (ex: https://xyzabc.supabase.co)
VITE_SUPABASE_URL=

# Chave anônima pública do Supabase (anon key)
VITE_SUPABASE_ANON_KEY=

# Chave de serviço do Supabase — SOMENTE para operações admin
# ⚠️ NUNCA exponha esta chave no frontend em produção
VITE_SUPABASE_SERVICE_ROLE_KEY=

# --- Admin ---
# E-mail do utilizador com perfil administrador
VITE_ADMIN_EMAIL=

# --- App (opcional) ---
# URL base da aplicação (usada em redirects de auth, etc.)
VITE_APP_URL=http://localhost:5173
